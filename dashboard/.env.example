# Copy to .env and fill in. dashboard/.env is gitignored.
#
# For local development against the local Supabase stack (supabase start),
# use the values it prints -- API_URL and ANON_KEY. The local anon key is
# a well-known, published default (same for every local Supabase project
# everywhere), not a real secret -- it's the SERVICE_ROLE_KEY that's
# sensitive and must never go in a VITE_-prefixed variable.
#
# For the real cloud project, get these from Supabase dashboard -> Project
# Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
