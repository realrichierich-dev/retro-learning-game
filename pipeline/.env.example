# Copy this file to .env and fill in your key (pipeline/.env is gitignored,
# it will never be committed).
#
# Get a key at https://console.anthropic.com/settings/keys -- requires an
# Anthropic account with billing enabled. Cost per pptx deck is well under
# a cent to a few cents using the cheap Haiku model this pipeline defaults
# to (see README.md "Cost" section).
ANTHROPIC_API_KEY=
